import java.util.Random;

public class UC4_MovePosition {
    public static void main(String[] args) {

        int position = 0;

        Random rand = new Random();
        int dice = rand.nextInt(6) + 1;
        int option = rand.nextInt(3);

        if (option == 1) {
            position += dice;
        } else if (option == 2) {
            position -= dice;
        }

        if (position < 0)
            position = 0;

        System.out.println("Position: " + position);
    }
}
