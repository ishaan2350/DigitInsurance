public class SumArgs {
    public static void main(String[] args) {
        int sum = 0, invalid = 0;

        for (String arg : args) {
            try {
                sum += Integer.parseInt(arg);
            } catch (NumberFormatException e) {
                invalid++;
            }
        }

        System.out.println("Sum = " + sum);
        System.out.println("Invalid inputs = " + invalid);
    }
}
