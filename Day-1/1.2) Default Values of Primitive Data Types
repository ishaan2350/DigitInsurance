public class DefaultValues {
    static int i;
    static float f;
    static double d;
    static boolean b;
    static char c;

    public static void main(String[] args) {
        System.out.println("int: " + i);
        System.out.println("float: " + f);
        System.out.println("double: " + d);
        System.out.println("boolean: " + b);
        System.out.println("char: [" + c + "]");
    }
}
