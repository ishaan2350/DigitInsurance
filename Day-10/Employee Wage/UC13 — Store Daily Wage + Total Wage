import java.util.*;

public class UC13_DailyWage {

    public static void main(String[] args) {

        ArrayList<Integer> daily = new ArrayList<>();

        daily.add(100);
        daily.add(200);
        daily.add(150);

        int total = 0;

        for (int d : daily)
            total += d;

        System.out.println("Total Wage: " + total);
    }
}
