public class UC2_MaxFloat {

    public static Float findMax(Float a, Float b, Float c) {

        Float max = a;

        if (b.compareTo(max) > 0)
            max = b;

        if (c.compareTo(max) > 0)
            max = c;

        return max;
    }

    public static void main(String[] args) {

        System.out.println(findMax(3.2f, 2.1f, 1.5f));
        System.out.println(findMax(1.2f, 3.5f, 2.8f));
        System.out.println(findMax(1.2f, 2.5f, 4.8f));
    }
}
